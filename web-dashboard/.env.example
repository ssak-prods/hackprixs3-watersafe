# WaterSafe V2 — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to Git.

# ─── Twilio SMS Credentials ───────────────────────────────────────────────────
# Sign up free at https://twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX   # Your Twilio number (not your personal number)

# ─── Deployment Config ────────────────────────────────────────────────────────
SOURCE_NAME=Water Source #1        # Name shown in SMS messages (e.g. "Village Well A")
PORT=3000
